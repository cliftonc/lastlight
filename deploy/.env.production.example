# ── Last Light — Production Environment ──────────────────────────
# Copy this file to instance/secrets/.env and fill in your values, where
# instance/ is your private deployment overlay (a separate repo cloned next to
# docker-compose.yml). The whole instance/ folder is mounted read-only into the
# container at /app/instance; the entrypoint reads secrets from
# /app/instance/secrets, and both the agent and caddy services read this file
# via env_file. No repo-root .env is needed.
#
# Overlay (config.yaml + agent-context/ + workflows/ + skills/) is read at
# startup — edit and `docker compose restart agent` to apply, no rebuild.
LASTLIGHT_OVERLAY_DIR=/app/instance

# =================================================================
# LLM PROVIDER (pick one)
# =================================================================

# Anthropic (direct — recommended for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (many models, one key — https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-...

# OpenAI models via API key (use openrouter provider in config.yaml):
# OPENROUTER_API_KEY=sk-proj-...           # your OpenAI API key
# OPENROUTER_BASE_URL=https://api.openai.com/v1
#
# Note: openai-codex requires interactive OAuth login (hermes login)
# and will NOT work in headless/Docker deployments.

# =================================================================
# GITHUB APP (required)
# =================================================================
# Create a GitHub App: https://docs.github.com/en/apps/creating-github-apps
# Permissions needed: Issues (R/W), Pull Requests (R/W), Contents (R/W), Metadata (R)

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./your-app.private-key.pem
GITHUB_APP_INSTALLATION_ID=

# =================================================================
# TERMINAL BACKEND (where the agent runs code)
# =================================================================
# Modal is recommended — cloud VMs with auto-scaling, no Docker-in-Docker.
# Get credentials: pip install modal && modal token new

MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Alternative: Daytona (https://daytona.io)
# DAYTONA_API_KEY=

# =================================================================
# WEBHOOK
# =================================================================
# Must match the secret in your GitHub App's webhook settings.

WEBHOOK_ENABLED=true
WEBHOOK_SECRET=change-me-to-a-random-string

# =================================================================
# DOMAIN (for Caddy TLS)
# =================================================================
# Set to your public hostname for automatic Let's Encrypt TLS.
# Leave empty or "localhost" for local dev (HTTP only).

DOMAIN=localhost

# =================================================================
# AGENT LIMITS
# =================================================================

HERMES_AGENT_TIMEOUT=1800

# =================================================================
# OPTIONAL: WEB SEARCH (explore workflow only)
# =================================================================
# Set any one to enable agentic-pi's `web_search` / `web_fetch` tools
# for the explore workflow. Provider auto-detected from whichever key
# is set (Tavily > Exa > Brave). Other workflows ignore these keys.
# TAVILY_API_KEY=tvly-...
# BRAVE_SEARCH_API_KEY=BSA...
# EXA_API_KEY=...

# =================================================================
# OPTIONAL: FALLBACK MODEL
# =================================================================
# Automatic failover when primary LLM provider rate-limits.
# Configured in config.yaml under fallback_model.

# ANTHROPIC_API_KEY=sk-ant-...  (if using OpenRouter as primary)

# =================================================================
# OPTIONAL: DISCORD
# =================================================================
# DISCORD_BOT_TOKEN=
# DISCORD_HOME_CHANNEL=
# GATEWAY_ALLOW_ALL_USERS=false
