# Secrets — never bake into the image. NOTE: unlike .gitignore, dockerignore
# patterns are anchored to the context root, so nested paths (e.g.
# apps/server/secrets) need the **/ form explicitly.
.env
**/.env
*.pem
**/*.pem
secrets/
**/secrets/
instance/
.gh-token
.github-token-cache.json
auth.json
auth.lock
.gitconfig-bot

# Dependencies + build caches — the image build installs and compiles its own
# (**/ forms cover apps/server/node_modules, apps/server/dashboard/node_modules,
# local dist/ dirs, etc.; the build stage rebuilds dists itself)
node_modules/
**/node_modules/
.turbo/
**/.turbo/
dist/
**/dist/
*.tsbuildinfo
**/*.tsbuildinfo

# Runtime state
data/
**/data/
sessions/
**/sessions/
logs/
**/logs/
memories/
cache/
checkpoints/
sandboxes/
**/sandboxes/
pairing/
hooks/
cron/output/
platforms/

# Git & editor
.git/
.gitignore
.DS_Store
.vscode/

# Dependencies (rebuilt in image)
mcp-github-app/node_modules/

# Database files
*.db
**/*.db
*.db-shm
**/*.db-shm
*.db-wal
**/*.db-wal

# Bundled Hermes skills (agent installs its own)
skills/.bundled_manifest
skills/apple/
skills/autonomous-ai-agents/
skills/creative/
skills/data-science/
skills/diagramming/
skills/domain/
skills/email/
skills/feeds/
skills/gaming/
skills/gifs/
skills/inference-sh/
skills/leisure/
skills/media/
skills/mlops/
skills/note-taking/
skills/productivity/
skills/red-teaming/
skills/research/
skills/smart-home/
skills/social-media/

# Misc
*.pid
*.lock
gateway_state.json
gateway.pid
channel_directory.json
discord_threads.json
modal_snapshots.json
response_store.db*
state.db*
.hermes_history
.update_check
.skills_prompt_snapshot.json
