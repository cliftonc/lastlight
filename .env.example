# ── Last Light Agent — Environment Variables ─────────────────────
# Copy to .env and fill in your values:  cp .env.example .env

# GitHub Personal Access Token (required)
# Create at: https://github.com/settings/tokens?type=beta
# Permissions needed: Issues (rw), Pull Requests (rw), Contents (read), Metadata (read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API Key (required for LLM)
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web search (optional — for researching issues/context)
# FIRECRAWL_API_KEY=
# TAVILY_API_KEY=
