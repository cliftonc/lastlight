# ── Last Light Agent — Environment Variables ─────────────────────
# Copy to .env and fill in your values:  cp .env.example .env

# ── GitHub App (required) ────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
# See README for full setup instructions
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./your-app-name.private-key.pem
GITHUB_APP_INSTALLATION_ID=789012

# ── LLM Provider (required — at least one) ──────────────────────
# OpenRouter (default)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Terminal Backend (optional) ──────────────────────────────────
# Modal — cloud sandboxed execution
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...

# SSH — remote server execution
# TERMINAL_SSH_HOST=my-server.example.com
# TERMINAL_SSH_USER=ubuntu
# TERMINAL_SSH_PORT=22
# TERMINAL_SSH_KEY=~/.ssh/id_rsa

# Daytona — managed cloud dev environments
# DAYTONA_API_KEY=...

# ── Gateway (optional — Discord/Telegram/Slack) ─────────────────
# DISCORD_BOT_TOKEN=
# DISCORD_HOME_CHANNEL=

# ── Agent Timeout ────────────────────────────────────────────────
# Max seconds for a single agent run via gateway (default 600).
# Build requests via webhooks can take longer. Set to 0 for no limit.
# HERMES_AGENT_TIMEOUT=1800

# ── Web Search (optional) ───────────────────────────────────────
# FIRECRAWL_API_KEY=
# TAVILY_API_KEY=
