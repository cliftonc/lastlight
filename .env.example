# ── Last Light Agent — Environment Variables ─────────────────────
# Copy to .env and fill in your values:  cp .env.example .env

# ── GitHub App (required) ────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
# See README for full setup instructions
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./your-app-name.private-key.pem
GITHUB_APP_INSTALLATION_ID=789012
# Bot identity for git commits (look up bot user ID at:
#   https://api.github.com/users/your-app-name%5Bbot%5D )
GITHUB_APP_BOT_NAME=your-app-name
GITHUB_APP_BOT_USER_ID=12345678

# ── LLM Provider (required — at least one) ──────────────────────
# Option A: OpenAI Codex OAuth (recommended — free with ChatGPT Plus)
#   Run `hermes login` locally, then copy ~/.hermes/auth.json to secrets/
#   The entrypoint symlinks it into the container automatically.
#   No API key env var needed — uses OAuth tokens from auth.json.
#
# Option B: OpenRouter (one key, many models)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option C: Direct OpenAI API key
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Terminal Backend (optional) ──────────────────────────────────
# Modal — cloud sandboxed execution
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...

# SSH — remote server execution
# TERMINAL_SSH_HOST=my-server.example.com
# TERMINAL_SSH_USER=ubuntu
# TERMINAL_SSH_PORT=22
# TERMINAL_SSH_KEY=~/.ssh/id_rsa

# Daytona — managed cloud dev environments
# DAYTONA_API_KEY=...

# ── Gateway (optional — Discord/Telegram/Slack) ─────────────────
# DISCORD_BOT_TOKEN=
# DISCORD_HOME_CHANNEL=

# ── Agent Timeout & Iterations ───────────────────────────────────
# Max seconds for a single agent run via gateway (default 600).
# Build requests via webhooks need the full Architect→Executor→Reviewer
# cycle which can take 30-60+ minutes. Set to 0 for no limit.
HERMES_AGENT_TIMEOUT=3600
# Max tool-call iterations per session (default 90 for gateway).
# The orchestrator + delegated subagents need headroom for multi-phase work.
HERMES_MAX_ITERATIONS=200

# ── Web Search (optional) ───────────────────────────────────────
# FIRECRAWL_API_KEY=
# TAVILY_API_KEY=
