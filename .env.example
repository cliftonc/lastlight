# ── Last Light — Environment Variables ─────────────────────
# Copy to .env and fill in your values:  cp .env.example .env

# ── GitHub App (required) ────────────────────────────────
# Create at: https://github.com/settings/apps/new
# See README for full setup instructions
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./your-app-name.private-key.pem
GITHUB_APP_INSTALLATION_ID=789012

# ── Webhook (required) ──────────────────────────────────
# Must match the secret configured in your GitHub App webhook settings
WEBHOOK_SECRET=your-webhook-secret

# ── Claude API (optional) ───────────────────────────────
# If set, uses API credits. If not set, uses your Claude Code login (subscription).
# For Docker: either set this, or run `docker exec -it lastlight-agent-1 claude login`
# ANTHROPIC_API_KEY=sk-ant-...

# ── Execution (optional) ──────────────────────────────────────
# Agents run in Docker sandbox containers by default.
# Set to allow direct execution without Docker (local dev only).
# ENABLE_DIRECT_FALLBACK=true

# ── Agent Settings (optional) ───────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6        # Default model (used when no per-type override)
# CLAUDE_MODELS={"architect":"claude-opus-4-6"}  # Per-task model overrides (JSON)
# Note: chat is intentionally NOT overridden — it inherits CLAUDE_MODEL (sonnet
# by default). Earlier we set chat=haiku for cost, but Haiku tends to refuse
# tool calls (e.g., create_issue) on the assumption it lacks permission.
# Task types: guardrails, architect, executor, reviewer, fix, pr, pr-fix, resume, triage, review, health, chat
# MAX_TURNS=200                          # Max agent turns per invocation
# PORT=8644                              # Webhook listener port
# STATE_DIR=./data                       # Persistent state directory
# BOT_LOGIN=last-light[bot]             # Bot login for self-event filtering
