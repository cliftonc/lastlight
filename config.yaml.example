# ── Last Light — Configuration ────────────────────────────────────
# Copy to config.yaml and customise:  cp config.yaml.example config.yaml
# Full reference: https://hermes-agent.nousresearch.com/docs/user-guide/configuration

# ── Model ────────────────────────────────────────────────────────
# Choose your LLM provider and model. Set the matching API key in .env.
#
# Provider options (API key providers — work unattended in Docker):
#   openrouter     → OPENROUTER_API_KEY    (many models, one key — recommended)
#   anthropic      → ANTHROPIC_API_KEY     (Claude models)
#   zai            → ZAI_API_KEY           (Z.AI / GLM models)
#   kimi-coding    → KIMI_API_KEY          (Kimi / Moonshot)
#   minimax        → MINIMAX_API_KEY       (MiniMax)
#
# OAuth providers (require interactive `hermes login` — won't work headless):
#   openai-codex   → ChatGPT Codex         (needs browser login + base_url)
#   nous           → OAuth (hermes login)  (Nous Portal)
#
# To use OpenAI models (GPT-4o, GPT-5.4, etc.) with an API key, use
# openrouter as the provider and set OPENROUTER_BASE_URL=https://api.openai.com/v1
# with OPENROUTER_API_KEY set to your OpenAI sk-proj-... key.
#
model:
  default: anthropic/claude-sonnet-4    # change to your preferred model
  provider: openrouter                  # change to your preferred provider
# base_url: https://chatgpt.com/backend-api/codex  # only needed for openai-codex

# ── Agent ────────────────────────────────────────────────────────
agent:
  max_turns: 200
  tool_use_enforcement: auto
  reasoning_effort: medium

# ── Terminal Backend ─────────────────────────────────────────────
# Where the agent runs commands.
# Options: local, docker, modal, ssh, daytona, singularity
#
# local       → runs on your machine (no isolation — not recommended)
# docker      → sandboxed container (needs Docker installed)
# modal       → cloud VM sandbox (needs MODAL_TOKEN_ID/SECRET in .env)
# ssh         → remote server (needs TERMINAL_SSH_HOST/USER in .env)
# daytona     → managed cloud env (needs DAYTONA_API_KEY in .env)
# singularity → HPC clusters (needs apptainer/singularity in $PATH)
#
terminal:
  backend: docker                       # change to your preferred backend
  cwd: .                                # resolves to $HOME (=/root in docker)
  timeout: 180
  env_passthrough:
  - GITHUB_TOKEN
  docker_image: nikolaik/python-nodejs:python3.11-nodejs20
  modal_image: nikolaik/python-nodejs:python3.11-nodejs20
  daytona_image: nikolaik/python-nodejs:python3.11-nodejs20
  singularity_image: docker://nikolaik/python-nodejs:python3.11-nodejs20
  container_cpu: 1
  container_memory: 5120        # MB
  container_disk: 51200         # MB
  container_persistent: true
  persistent_shell: true
  lifetime_seconds: 3600

# ── Delegation ───────────────────────────────────────────────────
# Controls sub-agent spawning (e.g. for parallel tasks).
delegation:
  max_iterations: 200

# ── MCP Servers ──────────────────────────────────────────────────
# The GitHub App MCP server provides 28 tools for repo management.
# Update the env values to match your GitHub App credentials from .env.
mcp_servers:
  github:
    command: node
    args:
    - ${HERMES_HOME}/mcp-github-app/src/index.js
    env:
      GITHUB_APP_ID: ${GITHUB_APP_ID}
      GITHUB_APP_PRIVATE_KEY_PATH: ${GITHUB_APP_PRIVATE_KEY_PATH}
      GITHUB_APP_INSTALLATION_ID: ${GITHUB_APP_INSTALLATION_ID}

# ── Display ──────────────────────────────────────────────────────
display:
  compact: true
  personality: concise
  streaming: true
  show_cost: true

# ── Memory ───────────────────────────────────────────────────────
memory:
  memory_enabled: true

# ── Auxiliary LLM calls ──────────────────────────────────────────
# Hermes uses LLMs for internal tasks (session summarisation, compression,
# vision, web extraction, etc). If you don't set these, Hermes picks a
# default that may not match your configured provider and will 401.
# Point these at a cheap/fast model using the same provider as your main
# model so they share credentials. gpt-4o-mini works well for all of these.
compression:
  enabled: true
  summary_provider: openrouter
  summary_model: gpt-4o-mini

auxiliary:
  session_search:
    provider: openrouter
    model: gpt-4o-mini
  vision:
    provider: openrouter
    model: gpt-4o-mini
  web_extract:
    provider: openrouter
    model: gpt-4o-mini
  compression:
    provider: openrouter
    model: gpt-4o-mini
  skills_hub:
    provider: openrouter
    model: gpt-4o-mini
  mcp:
    provider: openrouter
    model: gpt-4o-mini
  flush_memories:
    provider: openrouter
    model: gpt-4o-mini

# ── Cron ─────────────────────────────────────────────────────────
cron:
  wrap_response: true

# ── Gateway Platforms ────────────────────────────────────────────
# Which tools each platform can use when connected via gateway.
discord:
  require_mention: true
  auto_thread: true
  reactions: true

platform_toolsets:
  cli:
  - browser
  - code_execution
  - cronjob
  - delegation
  - file
  - memory
  - session_search
  - skills
  - terminal
  - todo
  - vision
  - web
  discord:
  - browser
  - code_execution
  - cronjob
  - delegation
  - file
  - memory
  - session_search
  - skills
  - terminal
  - todo
  - vision
  - web

# ── Skills ───────────────────────────────────────────────────────
# Internal skills (architect, plan, TDD, etc.) are disabled from auto-selection
# so the LLM doesn't bypass the github-orchestrator workflow. They're still
# usable via delegate_task inside the orchestrator.
skills:
  disabled:
    - architect
    - assure-guardrails
    - subagent-driven-development
    - requesting-code-review
    - test-driven-development
    - systematic-debugging
    - plan

# ── Webhook Platform (optional) ──────────────────────────────────
# React to GitHub events in real time. Point your GitHub App's webhook
# URL at http://your-host:8644/webhooks/github with the same secret.
# The github-orchestrator skill handles the logic — edit skills/github-orchestrator/SKILL.md.
#
# platforms:
#   webhook:
#     enabled: true
#     extra:
#       host: "0.0.0.0"
#       port: 8644
#       routes:
#         github:
#           secret: "your-webhook-secret"
#           events: ["issues", "pull_request", "issue_comment", "pull_request_review_comment", "pull_request_review"]
#           skills: ["github-orchestrator"]
#           prompt: |
#             CRITICAL: If action is "deleted", "edited", "labeled", "unlabeled",
#             "assigned", "closed", or "synchronize", respond ONLY with "No action needed."
#             and STOP immediately. Do NOT begin any work.
#
#             GitHub event: {_event_type}, action: {action}
#             Repository: {repository.full_name}
#             Issue/PR: #{issue.number} {issue.title}
#             Issue author: {issue.user.login}
#             Issue body: {issue.body}
#             Comment by: {comment.user.login}
#             Comment: {comment.body}
#             Sender: {sender.login}
#             Sender type: {sender.type}
#             Bot mention name: @your-app-name
#           deliver: log

# ── Fallback Model (optional) ───────────────────────────────────
# Automatic provider failover when primary is unavailable.
# Triggers on rate limits (429), overload (529), service errors (503).
#
# fallback_model:
#   provider: openrouter
#   model: anthropic/claude-sonnet-4
