{
  "name": "lastlight",
  "version": "2.0.0",
  "description": "GitHub repository maintenance agent — Agent SDK harness",
  "type": "module",
  "main": "dist/index.js",
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "build": "tsc",
    "build:dashboard": "npm run build -w dashboard",
    "build:all": "tsc && npm run build -w dashboard",
    "start": "node dist/index.js",
    "dev": "concurrently -n server,dash -c blue,magenta \"tsx watch src/index.ts\" \"npm run dev -w dashboard\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:dashboard": "npm run dev -w dashboard",
    "cli": "tsx src/cli.ts",
    "build:issue": "tsx src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "better-sqlite3": "^11.0.0",
    "croner": "^9.0.0",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
