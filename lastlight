#!/usr/bin/env bash
# ── Last Light — GitHub Maintenance Agent Launcher ──────────────────────
# Wraps `hermes` with HERMES_HOME pointed at this directory so all
# config, skills, memories, and state are local.
#
# Usage:
#   ./lastlight                        # interactive mode
#   ./lastlight chat -q "..."          # single query
#   ./lastlight gateway                # start gateway (Discord, etc.)
#   ./lastlight -s pr-review -q "Review PR #42 on owner/repo"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export HERMES_HOME="$SCRIPT_DIR"

# Load local .env if it exists (for GITHUB_TOKEN, OPENROUTER_API_KEY, etc.)
if [[ -f "$SCRIPT_DIR/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$SCRIPT_DIR/.env"
  set +a
fi

# If GitHub App credentials are set, generate an installation token
# and export it as GITHUB_PERSONAL_ACCESS_TOKEN for the MCP server.
if [[ -n "${GITHUB_APP_ID:-}" && -n "${GITHUB_APP_PRIVATE_KEY_PATH:-}" && -n "${GITHUB_APP_INSTALLATION_ID:-}" ]]; then
  echo "🔑 Generating GitHub App installation token..."
  token=$("$SCRIPT_DIR/scripts/github-app-token.sh" 2>&1) || {
    echo "⚠️  Failed to get GitHub App token: $token" >&2
    echo "   Falling back to GITHUB_TOKEN if set." >&2
    token=""
  }
  if [[ -n "$token" ]]; then
    export GITHUB_PERSONAL_ACCESS_TOKEN="$token"
    # Write token file so Hermes credential_files sync picks it up
    # in all sandbox backends (Modal, Docker, SSH, Daytona, local).
    printf '%s' "$token" > "$SCRIPT_DIR/.gh-token"
    chmod 600 "$SCRIPT_DIR/.gh-token"
  fi
# Fall back to GITHUB_TOKEN as a PAT
elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
  export GITHUB_PERSONAL_ACCESS_TOKEN="$GITHUB_TOKEN"
fi

exec hermes "$@"
